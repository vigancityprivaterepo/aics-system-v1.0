# Server
PORT=5001
NODE_ENV=production
API_BASE_URL=http://localhost:5001
TRUST_PROXY=true
RATE_LIMIT_MODE=memory

# CORS
# Required in production. Comma-separated list of allowed frontend origins.
CORS_ORIGIN=http://localhost:8080,http://localhost:8081

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/aics_db?schema=public

# Auth
# JWT_SECRET and PORTAL_JWT_SECRET must be different and at least 32 chars in production.
JWT_SECRET=replace-with-a-strong-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
PORTAL_JWT_SECRET=replace-with-a-different-strong-secret-at-least-32-characters
PORTAL_JWT_EXPIRES_IN=30d
DOCUMENT_VERIFY_SECRET=replace-with-a-third-strong-secret-at-least-32-characters

# Optional: LibreOffice binary path for DOCX -> PDF conversion when using exact Office-style PDFs.
LIBREOFFICE_PATH=

# Status notifications
PORTAL_EMAIL_NOTIFICATION_STATUSES=approved

# Business rules
BURIAL_GL_MAX_AMOUNT=10000
HOSPITAL_GL_MAX_AMOUNT=10000

# Storage
# All runtime uploads are stored under backend/uploads by default.
UPLOAD_ROOT=uploads

# SMTP
# Required in production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AICS Vigan City <noreply@vigancity.gov.ph>

# Semaphore SMS
# Required in production.
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_ID=AICS

# Anthropic Claude
# Optional for launch.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Seed protection
# Leave unset in production unless intentionally running a one-off seed.
ALLOW_PRODUCTION_SEED=false
